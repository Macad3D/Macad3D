﻿<UserControl
    x:Class="Macad.Window.MainWindowRibbon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Fluent="clr-namespace:Fluent;assembly=Fluent"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mmi="clr-namespace:Macad.Interaction;assembly=Macad.Interaction"
    xmlns:mmp="clr-namespace:Macad.Presentation;assembly=Macad.Presentation"
    xmlns:mmw="clr-namespace:Macad.Window"
    xmlns:panels="clr-namespace:Macad.Interaction.Panels;assembly=Macad.Interaction"
    d:DesignWidth="1280"
    KeyDown="_KeyDown"
    mc:Ignorable="d">

    <Fluent:Ribbon
        x:Name="Ribbon"
        AutomaticStateManagement="False"
        CanUseSimplified="False"
        ContentGapHeight="2"
        ContentHeight="90">

        <!--  region Quick access  -->
        <Fluent:Ribbon.QuickAccessItems>
            <Fluent:QuickAccessMenuItem IsChecked="True" Target="{Binding ElementName=SaveAllMenuItem}" />
            <Fluent:QuickAccessMenuItem IsChecked="True" Target="{Binding ElementName=UndoButton}" />
            <Fluent:QuickAccessMenuItem IsChecked="True" Target="{Binding ElementName=RedoButton}" />
        </Fluent:Ribbon.QuickAccessItems>
        <!--  endregion  -->

        <!--  region Contextual Groups  -->
        <Fluent:Ribbon.ContextualGroups>
            <Fluent:RibbonContextualTabGroup
                x:Name="SketchGroup"
                Background="Green"
                Header="Sketch"
                IsVisibleChanged="_ContextualGroup_IsVisibleChanged"
                Visibility="{Binding Context.EditorState.SketchGroupVisible, Converter={mmp:BoolToVisibleCollapsedConverter}}" />
        </Fluent:Ribbon.ContextualGroups>
        <!--  endregion  -->

        <!--  region Toolbar  -->
        <Fluent:Ribbon.ToolBarItems>
            <Fluent:Button
                mmp:Command.Action="{x:Static mmw:AppCommands.ShowShortcutCheatSheet}"
                AutomationProperties.AutomationId="ToolbarShowShortcutCheatSheet"
                Size="Small" />
            <Fluent:Button
                Command="{x:Static mmw:AppCommands.ShowHelpTopic}"
                Icon="{DynamicResource Fluent.Ribbon.Images.Help}"
                Size="Small" />
        </Fluent:Ribbon.ToolBarItems>
        <!--  endregion  -->

        <!--  region App menu  -->
        <Fluent:Ribbon.Menu>
            <Fluent:ApplicationMenu
                x:Name="RibbonFileMenu"
                AutomationProperties.AutomationId="File"
                Header="FILE"
                IsDropDownOpen="False"
                MaxDropDownHeight="500"
                RightPaneWidth="350">

                <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:DocumentCommands.CreateNewModel}" AutomationProperties.AutomationId="AppMenuNewModel" />
                <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:DocumentCommands.OpenModelFrom}" />
                <Fluent:MenuItem
                    AutomationProperties.AutomationId="AppMenuSettings"
                    Header="Settings"
                    Icon="{mmp:IconResource App-Settings}">
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmw:AppCommands.ShowPreferencesDialog}" AutomationProperties.AutomationId="AppMenuPreferencesDialog" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmw:AppCommands.ResetWindowLayout}" />
                </Fluent:MenuItem>

                <Separator />

                <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:DocumentCommands.SaveModel}" AutomationProperties.AutomationId="AppMenuSaveModel" />
                <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:DocumentCommands.SaveModelAs}" AutomationProperties.AutomationId="AppMenuSaveModelAs" />
                <Fluent:MenuItem x:Name="SaveAllMenuItem" mmp:Command.Action="{x:Static mmi:DocumentCommands.SaveAll}" />
                <Separator />

                <Fluent:MenuItem
                    AutomationProperties.AutomationId="AppMenuExchange"
                    Header="Exchange"
                    Icon="{mmp:IconResource App-Exchange}">
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ExchangeCommands.ImportFileToModel}" AutomationProperties.AutomationId="AppMenuImportFileToModel" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ExchangeCommands.ImportFileToSketch}" AutomationProperties.AutomationId="AppMenuImportFileToSketch" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ExchangeCommands.ExportVisibleBrep}" AutomationProperties.AutomationId="AppMenuExportVisibleBrep" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ExchangeCommands.ExportSelectedBrep}" AutomationProperties.AutomationId="AppMenuExportSelectedBrep" />
                </Fluent:MenuItem>

                <Separator />

                <Fluent:MenuItem mmp:Command.Action="{x:Static mmw:AppCommands.ShowHelpTopic}" />
                <Fluent:MenuItem mmp:Command.Action="{x:Static mmw:AppCommands.ShowAboutDialog}" AutomationProperties.AutomationId="AppMenuShowAboutDialog" />
                <Separator />

                <Fluent:MenuItem mmp:Command.Action="{x:Static mmw:AppCommands.ExitApplication}" />

                <Fluent:ApplicationMenu.RightPaneContent>
                    <StackPanel VerticalAlignment="Top">
                        <Label Content="Recent Files" FontWeight="Bold" />
                        <Separator />
                        <ItemsControl HorizontalContentAlignment="Stretch" ItemsSource="{Binding Context.DocumentController.MruList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Fluent:MenuItem
                                        Click="_RecentFilesMenuItem_Click"
                                        Command="{x:Static mmi:DocumentCommands.OpenRecentFile}"
                                        CommandParameter="{Binding}"
                                        Header="{Binding}"
                                        Icon="{mmp:IconResource App-OpenRecent}"
                                        Style="{StaticResource Macad.Styles.MenuItem.MRU}"
                                        ToolTipService.InitialShowDelay="100">
                                        <Fluent:MenuItem.ToolTip>
                                            <ToolTip
                                                DataContext="{Binding PlacementTarget.DataContext, Converter={mmp:ExtractFileThumbnailConverter}, RelativeSource={RelativeSource Self}}"
                                                HorizontalOffset="-10"
                                                Placement="Right"
                                                VerticalOffset="-5"
                                                Visibility="{Binding Converter={mmp:NotNullToVisibleCollapsedConverter}}">
                                                <Image
                                                    MaxWidth="128"
                                                    MaxHeight="128"
                                                    RenderOptions.BitmapScalingMode="Fant"
                                                    Source="{Binding}" />
                                            </ToolTip>
                                        </Fluent:MenuItem.ToolTip>
                                    </Fluent:MenuItem>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Fluent:ApplicationMenu.RightPaneContent>

            </Fluent:ApplicationMenu>
        </Fluent:Ribbon.Menu>
        <!--  endregion  -->

        <!--  region Edit  -->
        <Fluent:RibbonTabItem
            AutomationProperties.AutomationId="Edit"
            Header="EDIT"
            IsSelected="True"
            ReduceOrder="Snapping,Edit,Grid,Snapping,Grid,Edit">

            <Fluent:RibbonGroupBox Name="Undo" Header="Undo">
                <Fluent:Button
                    x:Name="UndoButton"
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.DoUndo}"
                    AutomationProperties.AutomationId="Undo" />
                <Fluent:Button
                    x:Name="RedoButton"
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.DoRedo}"
                    AutomationProperties.AutomationId="Redo" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Edit" Header="Edit">
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.DuplicateEntity}"
                    AutomationProperties.AutomationId="Duplicate"
                    SizeDefinition="Large,Large,Small" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateReference}"
                    AutomationProperties.AutomationId="CreateReference"
                    SizeDefinition="Large,Large,Small" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.PasteFromClipboard}"
                    AutomationProperties.AutomationId="PasteClipboard"
                    SizeDefinition="Large,Large,Small" />

                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.CopyToClipboard}"
                    AutomationProperties.AutomationId="CopyClipboard"
                    Size="Large,Middle,Small" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.CutToClipboard}"
                    AutomationProperties.AutomationId="CutClipboard"
                    Size="Large,Middle,Small" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.DeleteEntity}"
                    AutomationProperties.AutomationId="Delete"
                    Size="Large,Middle,Small" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Selection" Header="Selection">
                <Fluent:DropDownButton
                    AutomationProperties.AutomationId="RubberbandMode"
                    Header="Rubberband Mode"
                    Icon="{Binding Context.EditorState.RubberbandSelectionMode, Converter={mmp:CommandToIconConverter}, ConverterParameter={x:Static mmi:WorkspaceCommands.SetRubberbandSelectionMode}}"
                    LargeIcon="{Binding Context.EditorState.RubberbandSelectionMode, Converter={mmp:CommandToIconConverter}, ConverterParameter={x:Static mmi:WorkspaceCommands.SetRubberbandSelectionMode}}">
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetRubberbandSelectionMode}"
                        AutomationProperties.AutomationId="RubberbandModeRectangle"
                        CommandParameter="Rectangle" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetRubberbandSelectionMode}"
                        AutomationProperties.AutomationId="RubberbandModeFreehand"
                        CommandParameter="Freehand" />

                    <Fluent:GroupSeparatorMenuItem Header="Options" />

                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleRubberbandIncludeTouched}" AutomationProperties.AutomationId="RubberbandIncludeTouched" />
                </Fluent:DropDownButton>

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleIsolateSelection}" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox
                Name="Snapping"
                Grid.IsSharedSizeScope="True"
                Header="Snapping">
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleSnappingEnabled}"
                    AutomationProperties.AutomationId="SnapEnable"
                    SizeDefinition="Large,Large" />

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleSnapToGrid}"
                    AutomationProperties.AutomationId="SnapToGrid"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleSnapToVertex}"
                    AutomationProperties.AutomationId="SnapToVertex"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleSnapToEdge}"
                    AutomationProperties.AutomationId="SnapToEdge"
                    SizeDefinition="Large,Middle,Small" />

                <!--<fluent:Spinner Header="Tolerance"
                                    Minimum="1" Maximum="9.5" Format="0.0" Increment="0.5"
                                    Value="{Binding Context.EditorState.SnappingPixelTolerance}"/>-->
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="WorkingPlane" Header="Working Plane">
                <Fluent:DropDownButton
                    Header="Set"
                    Icon="{mmp:IconResource WorkingPlane-Set}"
                    LargeIcon="{mmp:IconResource WorkingPlane-Set}">
                    <Fluent:GroupSeparatorMenuItem Header="Default planes" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetWorkingPlane}" CommandParameter="0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetWorkingPlane}" CommandParameter="1" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetWorkingPlane}" CommandParameter="2" />
                </Fluent:DropDownButton>

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:WorkspaceCommands.AlignWorkingPlane}" AutomationProperties.AutomationId="AlignWorkingPlane" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox
                Name="Grid"
                Grid.IsSharedSizeScope="True"
                Header="Grid">
                <Fluent:SplitButton
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleGrid}"
                    AutomationProperties.AutomationId="ShowGrid"
                    SizeDefinition="Large,Large">

                    <Fluent:GroupSeparatorMenuItem Header="Grid Type" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridType}"
                        AutomationProperties.AutomationId="RectGrid"
                        CommandParameter="Rectangular"
                        SizeDefinition="Large,Small" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridType}"
                        AutomationProperties.AutomationId="CircGrid"
                        CommandParameter="Circular"
                        SizeDefinition="Large,Small" />
                </Fluent:SplitButton>

                <Fluent:DropDownButton mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" SizeDefinition="Large,Middle,Small">
                    <mmp:ValueEditBox
                        Width="Auto"
                        HorizontalAlignment="Stretch"
                        MaxValue="1000"
                        MinValue="0.01"
                        SourceUpdated="_CloseMenuOnSourceUpdated"
                        Units="Length"
                        Value="{Binding Context.Workspace.GridStep, NotifyOnSourceUpdated=True}" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="10.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="5.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="2.5" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="2.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="1.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="0.5" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="0.25" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="0.2" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridStepValue}" CommandParameter="0.1" />
                </Fluent:DropDownButton>

                <Fluent:DropDownButton mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" SizeDefinition="Large,Middle,Small">
                    <mmp:ValueEditBox
                        Width="Auto"
                        HorizontalAlignment="Stretch"
                        MaxValue="359.9"
                        MinValue="-359.9"
                        SourceUpdated="_CloseMenuOnSourceUpdated"
                        Units="Degree"
                        Value="{Binding Context.Workspace.GridRotation, NotifyOnSourceUpdated=True}" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="0.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="5.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="10.0" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="11.25" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="22.5" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="45" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="90" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="135" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="180" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridRotationValue}" CommandParameter="270" />
                </Fluent:DropDownButton>

                <Fluent:DropDownButton
                    mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}"
                    IsEnabled="{Binding Context.Workspace.GridType, Converter={mmp:EqualityToBoolConverter}, ConverterParameter=Circular}"
                    SizeDefinition="Large,Middle,Small">
                    <mmp:ValueEditBox
                        Width="Auto"
                        HorizontalAlignment="Stretch"
                        MaxValue="60"
                        MinValue="1"
                        Precision="0"
                        SourceUpdated="_CloseMenuOnSourceUpdated"
                        Units="None"
                        Value="{Binding Context.Workspace.GridDivisions, NotifyOnSourceUpdated=True}" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="3" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="4" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="5" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="6" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="8" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="12" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="18" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetGridDivisionsValue}" CommandParameter="36" />
                </Fluent:DropDownButton>

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="ArrangeGroup" Header="Arrange">
                <Fluent:SplitButton mmp:Command.Action="{x:Static mmi:WorkspaceCommands.Transform}" AutomationProperties.AutomationId="Transform">

                    <Fluent:GroupSeparatorMenuItem Header="Pivot Point" />

                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetTransformPivot}" CommandParameter="EntityPivot" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetTransformPivot}" CommandParameter="BoundingCenter" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetTransformPivot}" CommandParameter="MassCenter" />

                    <Fluent:GroupSeparatorMenuItem Header="Options" />

                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleTransformOption}" CommandParameter="MultipleUseFirst" />

                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleTransformOption}" CommandParameter="WorldSpaceOrientation" />

                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ToggleTransformOption}" CommandParameter="LinkForeignOperands" />
                </Fluent:SplitButton>

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Layer" Header="Layer">

                <Fluent:Button mmp:Command.Action="{x:Static mmw:AppCommands.ShowLayerEditor}" Header="Layer Editor" />

                <Fluent:RibbonToolBar>

                    <Fluent:RibbonToolBar.LayoutDefinitions>
                        <Fluent:RibbonToolBarLayoutDefinition>
                            <Fluent:RibbonToolBarRow>
                                <Fluent:RibbonToolBarControlDefinition Width="155" Target="Layers_ActiveLayerSelect" />
                            </Fluent:RibbonToolBarRow>
                            <Fluent:RibbonToolBarRow>
                                <Fluent:RibbonToolBarControlGroupDefinition>
                                    <Fluent:RibbonToolBarControlDefinition Target="Layers_MoveEntityToLayer" />
                                    <Fluent:RibbonToolBarControlDefinition Target="Layers_SelectAll" />
                                </Fluent:RibbonToolBarControlGroupDefinition>
                                <Fluent:RibbonToolBarControlGroupDefinition>
                                    <Fluent:RibbonToolBarControlDefinition Target="Layers_ActiveLayerLocked" />
                                    <Fluent:RibbonToolBarControlDefinition Target="Layers_ActiveLayerVisible" />
                                    <Fluent:RibbonToolBarControlDefinition Target="Layers_Isolated" />
                                </Fluent:RibbonToolBarControlGroupDefinition>
                                <Fluent:RibbonToolBarControlGroupDefinition>
                                    <Fluent:RibbonToolBarControlDefinition Target="Layers_ActiveLayerVisual" />
                                </Fluent:RibbonToolBarControlGroupDefinition>
                            </Fluent:RibbonToolBarRow>
                        </Fluent:RibbonToolBarLayoutDefinition>
                    </Fluent:RibbonToolBar.LayoutDefinitions>

                    <ComboBox
                        x:Name="Layers_ActiveLayerSelect"
                        Margin="0,10,0,0"
                        AutomationProperties.AutomationId="ActiveLayerSelect"
                        ItemsSource="{Binding Context.Layers}"
                        SelectedValue="{Binding Context.Layers.ActiveLayer}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <!--  Color  -->
                                    <Border
                                        Width="14"
                                        Height="14"
                                        Margin="1"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        DockPanel.Dock="Left"
                                        UseLayoutRounding="True">
                                        <Rectangle
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Fill="{Binding Color, Converter={mmp:ColorToBrushConverter}}" />
                                    </Border>
                                    <!--  Text  -->
                                    <TextBlock
                                        Margin="5,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>

                        <ComboBox.ToolTip>
                            <Fluent:ScreenTip Title="Active Layer" Text="Selected the active layer. New entities are created in this layer." />
                        </ComboBox.ToolTip>
                    </ComboBox>

                    <Fluent:Button
                        x:Name="Layers_MoveEntityToLayer"
                        mmp:Command.Action="{x:Static mmi:LayerCommands.MoveEntityToLayer}"
                        CommandParameter="{Binding Context.Layers.ActiveLayer}"
                        Size="Small" />

                    <Fluent:Button
                        x:Name="Layers_SelectAll"
                        mmp:Command.Action="{x:Static mmi:LayerCommands.SelectAllEntities}"
                        CommandParameter="{Binding Context.Layers.ActiveLayer}"
                        Size="Small" />

                    <Fluent:ToggleButton
                        x:Name="Layers_Isolated"
                        mmp:Command.Action="{x:Static mmi:LayerCommands.ToggleIsolation}"
                        CommandParameter="{Binding Context.Layers.ActiveLayer}"
                        Size="Small" />

                    <Fluent:ToggleButton
                        x:Name="Layers_ActiveLayerLocked"
                        mmp:Command.Action="{x:Static mmi:LayerCommands.ToggleIsLocked}"
                        CommandParameter="{Binding Context.Layers.ActiveLayer}"
                        Size="Small" />

                    <Fluent:ToggleButton
                        x:Name="Layers_ActiveLayerVisible"
                        mmp:Command.Action="{x:Static mmi:LayerCommands.ToggleIsVisible}"
                        CommandParameter="{Binding Context.Layers.ActiveLayer}"
                        IsChecked="{Binding Context.Layers.ActiveLayer.IsVisible, Mode=OneWay}"
                        Size="Small" />

                    <Fluent:DropDownButton
                        x:Name="Layers_ActiveLayerVisual"
                        mmp:Command.Action="{x:Static mmi:LayerCommands.LayerVisualPanel}"
                        AutomationProperties.AutomationId="ActiveLayerVisual"
                        Size="Small">

                        <Fluent:GroupSeparatorMenuItem Header="Layer Visuals" />
                        <panels:LayerVisualPanel DataContext="{Binding Context.Layers.ActiveLayer, Mode=OneWay}" />
                    </Fluent:DropDownButton>
                </Fluent:RibbonToolBar>
            </Fluent:RibbonGroupBox>

        </Fluent:RibbonTabItem>
        <!--  endregion  -->

        <!--  region Model  -->
        <Fluent:RibbonTabItem
            AutomationProperties.AutomationId="Model"
            Header="MODEL"
            ReduceOrder="Create,Form,Boolean,Modify,Multiply">

            <Fluent:RibbonGroupBox Name="Create" Header="Create">
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateBox}"
                    AutomationProperties.AutomationId="CreateBox"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateCylinder}"
                    AutomationProperties.AutomationId="CreateCylinder"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateSphere}"
                    AutomationProperties.AutomationId="CreateSphere"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:SplitButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateSketch}"
                    AutomationProperties.AutomationId="CreateSketch"
                    SizeDefinition="Large,Large,Large">
                    <Fluent:GroupSeparatorMenuItem Header="Sketch Plane Alignment" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ModelCommands.CreateSketchAligned}" CommandParameter="WorkplaneXY" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ModelCommands.CreateSketchAligned}" CommandParameter="WorkplaneXZ" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ModelCommands.CreateSketchAligned}" CommandParameter="WorkplaneYZ" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:ModelCommands.CreateSketchAligned}"
                        AutomationProperties.AutomationId="CreateSketchInteractive"
                        CommandParameter="Interactive" />
                </Fluent:SplitButton>
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Modify" Header="Modify">

                <Fluent:SplitButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateImprint}"
                    AutomationProperties.AutomationId="CreateImprint"
                    SizeDefinition="Large,Large,Large">
                    <Fluent:GroupSeparatorMenuItem Header="Imprint Mode" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ModelCommands.CreateImprint}" CommandParameter="Raise" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ModelCommands.CreateImprint}" CommandParameter="Lower" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:ModelCommands.CreateImprint}" CommandParameter="Cutout" />
                </Fluent:SplitButton>

                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateFillet}"
                    AutomationProperties.AutomationId="CreateFillet"
                    SizeDefinition="Large,Middle,Small" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateChamfer}"
                    AutomationProperties.AutomationId="CreateChamfer"
                    SizeDefinition="Large,Middle,Small" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateTaper}"
                    AutomationProperties.AutomationId="CreateTaper"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateOffset}"
                    AutomationProperties.AutomationId="CreateOffset"
                    SizeDefinition="Large,Middle,Small" />

                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateScale}"
                    AutomationProperties.AutomationId="CreateScale"
                    SizeDefinition="Large,Middle,Small" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Boolean" Header="Boolean">

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateBoolean}"
                    AutomationProperties.AutomationId="CreateBooleanCut"
                    CommandParameter="Cut" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateBoolean}"
                    AutomationProperties.AutomationId="CreateBooleanFuse"
                    CommandParameter="Fuse" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:ModelCommands.CreateBoolean}"
                    AutomationProperties.AutomationId="CreateBooleanCommon"
                    CommandParameter="Common" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:ModelCommands.CreateCrossSection}" AutomationProperties.AutomationId="CreateCrossSection" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Form" Header="Form">

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateExtrude}" AutomationProperties.AutomationId="CreateExtrude" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateRevolve}" AutomationProperties.AutomationId="CreateRevolve" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateLoft}" AutomationProperties.AutomationId="CreateLoft" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:ModelCommands.CreatePipe}" AutomationProperties.AutomationId="CreatePipe" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Multiply" Header="Multiply">

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateMirror}" AutomationProperties.AutomationId="CreateMirror" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateLinearArray}" AutomationProperties.AutomationId="CreateLinearArray" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateCircularArray}" AutomationProperties.AutomationId="CreateCircularArray" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Assembly" Header="Assembly">

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateBoxJoint}" AutomationProperties.AutomationId="CreateBoxJoint" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateHalvedJoint}" AutomationProperties.AutomationId="CreateHalvedJoint" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Sheet" Header="Sheet">

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateFlangeSheet}" AutomationProperties.AutomationId="CreateFlangeSheet" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ModelCommands.CreateUnfoldSheet}" AutomationProperties.AutomationId="CreateUnfoldSheet" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Auxiliary" Header="Auxiliary">

                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:AuxiliaryCommands.CreateDatumPlane}"
                    AutomationProperties.AutomationId="CreateDatumPlane"
                    SizeDefinition="Large,Large,Large" />
            </Fluent:RibbonGroupBox>
        </Fluent:RibbonTabItem>
        <!--  endregion  -->

        <!--  region Toolbox  -->
        <Fluent:RibbonTabItem AutomationProperties.AutomationId="Toolbox" Header="TOOLBOX">

            <Fluent:RibbonGroupBox Header="Convert">

                <Fluent:Button mmp:Command.Action="{x:Static mmi:ToolboxCommands.ConvertToEditableSketch}" AutomationProperties.AutomationId="ConvertToEditableSketch" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:ToolboxCommands.ConvertToSolid}" AutomationProperties.AutomationId="ConvertToSolid" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Header="Templates">

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ToolboxCommands.CreateSliceContour}" AutomationProperties.AutomationId="CreateSliceContour" />

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:ToolboxCommands.CreateEtchingMask}" AutomationProperties.AutomationId="CreateEtchingMask" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Header="Drawings">

                <Fluent:Button mmp:Command.Action="{x:Static mmi:ToolboxCommands.ExportViewHlr}" AutomationProperties.AutomationId="ExportViewHlr" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:ToolboxCommands.ExportPipeDrawing}" AutomationProperties.AutomationId="ExportPipeDrawing" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Header="Workflow">
                <Fluent:Button mmp:Command.Action="{x:Static mmw:AppCommands.ShowShapeInspector}" />

                <Fluent:SplitButton mmp:Command.Action="{x:Static mmi:ToolboxCommands.RunScriptFrom}" AutomationProperties.AutomationId="RunScript">
                    <mmp:Behaviors.Behavior>
                        <mmp:FluentDropDownCommandBehaviour OpenedCommand="{x:Static mmi:ToolboxCommands.PrewarmScriptCompiler}" />
                    </mmp:Behaviors.Behavior>

                    <Fluent:GroupSeparatorMenuItem Header="Recently Used Scripts" />
                    <ItemsControl ItemsSource="{Binding Context.RecentUsedScripts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Fluent:MenuItem
                                    Command="{x:Static mmi:ToolboxCommands.RunScriptCommand}"
                                    CommandParameter="{Binding}"
                                    Header="{Binding Converter={mmp:ExtractFileNameNoExtensionConverter}}">
                                    <Fluent:MenuItem.ToolTip>
                                        <Fluent:ScreenTip Title="{Binding Converter={mmp:ExtractFileNameConverter}}" Text="{Binding Converter={mmp:ExtractFileDirectoryConverter}}" />
                                    </Fluent:MenuItem.ToolTip>
                                </Fluent:MenuItem>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Fluent:SplitButton>
            </Fluent:RibbonGroupBox>

        </Fluent:RibbonTabItem>
        <!--  endregion  -->

        <!--  region View  -->
        <Fluent:RibbonTabItem AutomationProperties.AutomationId="View" Header="VIEW">
            <Fluent:RibbonGroupBox Header="View">
                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetPredefinedView}" CommandParameter="Front" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetPredefinedView}" CommandParameter="Top" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetPredefinedView}" CommandParameter="Right" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetPredefinedView}" CommandParameter="Left" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetPredefinedView}" CommandParameter="Bottom" />
                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetPredefinedView}" CommandParameter="Back" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Header="Zoom">

                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ZoomFitAll}" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ZoomFitSelected}" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ZoomIn}" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:WorkspaceCommands.ZoomOut}" />

            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Header="Display">

                <Fluent:DropDownButton
                    AutomationProperties.AutomationId="ViewRenderMode"
                    Header="Render Mode"
                    Icon="{Binding Context.Viewport.RenderMode, Converter={mmp:CommandToIconConverter}, ConverterParameter={x:Static mmi:WorkspaceCommands.SetRenderMode}}"
                    LargeIcon="{Binding Context.Viewport.RenderMode, Converter={mmp:CommandToIconConverter}, ConverterParameter={x:Static mmi:WorkspaceCommands.SetRenderMode}}">
                    <Fluent:GroupSeparatorMenuItem Header="Render Mode" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetRenderMode}"
                        AutomationProperties.AutomationId="ViewRenderModeSolidShaded"
                        CommandParameter="SolidShaded" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetRenderMode}"
                        AutomationProperties.AutomationId="ViewRenderModeHLR"
                        CommandParameter="HLR" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:WorkspaceCommands.SetRenderMode}"
                        AutomationProperties.AutomationId="ViewRenderModeRaytraced"
                        CommandParameter="Raytraced" />

                </Fluent:DropDownButton>

            </Fluent:RibbonGroupBox>
        </Fluent:RibbonTabItem>
        <!--  endregion  -->

        <!--  region Plugins  -->
        <Fluent:RibbonTabItem x:Name="PluginsTab" AutomationProperties.AutomationId="Plugins" Header="PLUGINS">
        </Fluent:RibbonTabItem>
        <!--  endregion  -->

        <!--  region Sketch  -->
        <Fluent:RibbonTabItem
            AutomationProperties.AutomationId="Sketch"
            Group="{Binding ElementName=SketchGroup}"
            Header="SKETCH"
            ReduceOrder="Segment,Constraint,Constraint,Tools">
            <Fluent:RibbonGroupBox Name="Segment" Header="Create Segment">

                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreatePolyLine}"
                    AutomationProperties.AutomationId="CreatePolyLineSegment"
                    CommandParameter="PolyLine" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateLineSegment"
                    CommandParameter="Line" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateBezier2Segment"
                    CommandParameter="Bezier2" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateBezier3Segment"
                    CommandParameter="Bezier3" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateRectangleSegment"
                    CommandParameter="Rectangle" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateCircleSegment"
                    CommandParameter="Circle" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateArcCenterSegment"
                    CommandParameter="ArcCenter" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateArcRimSegment"
                    CommandParameter="ArcRim" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateEllipseCenterSegment"
                    CommandParameter="EllipseCenter" />
                <Fluent:ToggleButton
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateSegment}"
                    AutomationProperties.AutomationId="CreateEllipticalArcCenterSegment"
                    CommandParameter="EllipticalArcCenter" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Constraint" Header="Create Constraint">
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateFixedConstraint"
                    CommandParameter="Fixed" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateLineLengthConstraint"
                    CommandParameter="LineLength" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateAngleConstraint"
                    CommandParameter="Angle" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateCircleRadiusConstraint"
                    CommandParameter="CircleRadius" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateEqualConstraint"
                    CommandParameter="Equal" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreatePerpendicularConstraint"
                    CommandParameter="Perpendicular" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateParallelConstraint"
                    CommandParameter="Parallel" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateConcentricConstraint"
                    CommandParameter="Concentric" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateHorizontalConstraint"
                    CommandParameter="Horizontal" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateVerticalConstraint"
                    CommandParameter="Vertical" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateHorizontalDistanceConstraint"
                    CommandParameter="HorizontalDistance" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateVerticalDistanceConstraint"
                    CommandParameter="VerticalDistance" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateTangentConstraint"
                    CommandParameter="Tangent" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreatePointOnSegmentConstraint"
                    CommandParameter="PointOnSegment" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreatePointOnMidpointConstraint"
                    CommandParameter="PointOnMidpoint" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.CreateConstraint}"
                    AutomationProperties.AutomationId="CreateSmoothCornerConstraint"
                    CommandParameter="SmoothCorner" />
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Tools" Header="Tools">
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:SketchCommands.SplitElement}" AutomationProperties.AutomationId="SplitElement" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:SketchCommands.WeldElements}" AutomationProperties.AutomationId="WeldElements" />

                <Fluent:DropDownButton
                    AutomationProperties.AutomationId="ConvertSegment"
                    Header="Convert Segment"
                    Icon="{mmp:IconResource Sketch-ConvertSegment}"
                    LargeIcon="{mmp:IconResource Sketch-ConvertSegment}">
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ConvertSegment}"
                        AutomationProperties.AutomationId="ConvertSegmentToLine"
                        CommandParameter="Line" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ConvertSegment}"
                        AutomationProperties.AutomationId="ConvertSegmentToBezier"
                        CommandParameter="Bezier" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ConvertSegment}"
                        AutomationProperties.AutomationId="ConvertSegmentToArc"
                        CommandParameter="Arc" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ConvertSegment}"
                        AutomationProperties.AutomationId="ConvertSegmentToEllipticalArc"
                        CommandParameter="EllipticalArc" />
                </Fluent:DropDownButton>

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:SketchCommands.ScaleElement}" AutomationProperties.AutomationId="ScaleElement" />

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:SketchCommands.MirrorElement}" AutomationProperties.AutomationId="MirrorElement" />

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:SketchCommands.OffsetSegment}" AutomationProperties.AutomationId="OffsetSegment" />

                <Fluent:DropDownButton
                    AutomationProperties.AutomationId="SketchExchange"
                    Header="Exchange"
                    Icon="{mmp:IconResource Sketch-Exchange}"
                    LargeIcon="{mmp:IconResource Sketch-Exchange}">

                    <Fluent:GroupSeparatorMenuItem Header="Export" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:SketchCommands.ExportAllToFile}" AutomationProperties.AutomationId="ExportAllToFile" />
                    <Fluent:MenuItem mmp:Command.Action="{x:Static mmi:SketchCommands.ExportAllToToSvgClipboard}" AutomationProperties.AutomationId="ExportAllToSvgClipboard" />

                    <Fluent:GroupSeparatorMenuItem Header="Import" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ImportFromFile}"
                        AutomationProperties.AutomationId="ImportFromFile"
                        CommandParameter="false" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ImportFromFile}"
                        AutomationProperties.AutomationId="ReplaceFromFile"
                        CommandParameter="true" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ImportFromClipboard}"
                        AutomationProperties.AutomationId="ImportFromClipboard"
                        CommandParameter="false" />
                    <Fluent:MenuItem
                        mmp:Command.Action="{x:Static mmi:SketchCommands.ImportFromClipboard}"
                        AutomationProperties.AutomationId="ReplaceFromClipboard"
                        CommandParameter="true" />
                </Fluent:DropDownButton>
            </Fluent:RibbonGroupBox>

            <Fluent:RibbonGroupBox Name="Editor" Header="Editor">
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.RotateSketchView}"
                    AutomationProperties.AutomationId="TurnSketchViewCCW"
                    CommandParameter="-90.0" />
                <Fluent:Button
                    mmp:Command.Action="{x:Static mmi:SketchCommands.RotateSketchView}"
                    AutomationProperties.AutomationId="TurnSketchViewCW"
                    CommandParameter="90.0" />
                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:SketchCommands.ToggleClippingPlane}" />

                <Fluent:ToggleButton mmp:Command.Action="{x:Static mmi:SketchCommands.RecenterGrid}" AutomationProperties.AutomationId="RecenterGrid" />

                <Fluent:Button mmp:Command.Action="{x:Static mmi:SketchCommands.CloseSketchEditor}" AutomationProperties.AutomationId="CloseSketchEditor" />
            </Fluent:RibbonGroupBox>
        </Fluent:RibbonTabItem>
        <!--  endregion  -->

    </Fluent:Ribbon>

</UserControl>
