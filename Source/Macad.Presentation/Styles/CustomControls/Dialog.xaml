<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mmp="clr-namespace:Macad.Presentation"
                    xmlns:controlzex="urn:controlzex">
    
    <Style TargetType="{x:Type mmp:Dialog}">
        <Setter Property="Foreground" Value="{mmp:AppResource Macad.Brushes.Text}" />
        <Setter Property="Background" Value="{mmp:AppResource Macad.Brushes.Popup.Background}" />
        <Setter Property="MinWidth" Value="240" />
        <Setter Property="MinHeight" Value="180" />
        <Setter Property="ShowInTaskbar" Value="False" />
        <Setter Property="ResizeMode" Value="NoResize" />
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="CornerPreference" Value="Round"/>
        <Setter Property="PreferDWMBorderColor" Value="True"/>
        <Setter Property="AllowsTransparency" Value="False"/>
        <Setter Property="GlowColor" Value="{mmp:AppResource Macad.Colors.Window.Border}"/>
        <Setter Property="NonActiveGlowColor" Value="{mmp:AppResource Macad.Colors.Window.Inactive.Border}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="mmp:Dialog">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <!-- title -->
                        <Grid controlzex:WindowChrome.IsHitTestVisibleInChrome="False"
                              controlzex:NonClientControlProperties.HitTestResult="CAPTION"
                              Background="{TemplateBinding Background}"
                              MinHeight="20">
                            <StackPanel Background="{mmp:AppResource Macad.Brushes.Popup.Header.Background}"
                                        Visibility="{TemplateBinding Title, Converter={mmp:StringNotEmptyToVisibleCollapsedConverter}}"
                                        Margin="0,0,0,5">
                                <TextBlock Text="{TemplateBinding Title}" 
                                           HorizontalAlignment="Left"
                                           Foreground="{mmp:AppResource Macad.Brushes.Popup.Header.Text}"
                                           Margin="20,5"
                                           FontFamily="Segoe UI"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />

                                <Rectangle Height="1"  Fill="{mmp:AppResource Macad.Brushes.Popup.Header.Border}" />
                            </StackPanel>

                            <!-- header -->
                            <ContentPresenter Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                              Margin="0,0" 
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>
                        
                        <!-- content -->
                        <Grid Grid.Row="1" 
                              Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="30,10,30,20" ScrollViewer.VerticalScrollBarVisibility="Disabled" />
                        </Grid>

                        <!-- footer -->
                        <Border Grid.Row="2" 
                                MinHeight="20"
                                BorderThickness="0,1,0,0" 
                                BorderBrush="{mmp:AppResource Macad.Brushes.Popup.Header.Border}"
                                Background="{mmp:AppResource Macad.Brushes.Popup.Header.Background}">
                            <ContentPresenter Grid.Row="2" Margin="20,5"
                                            Content="{Binding Footer, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>