<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Target for copy sub project additional output to main publish output -->
  <Target Name="GenerateGetCopyToPublishDirectoryItems"
          BeforeTargets="GetCopyToPublishDirectoryItems"
          Returns="@(AllPublishItemsFullPathWithTargetPath)">

    <ItemGroup>
      <AllPublishItemsFullPathWithTargetPath Include="@(CopyToOutput)">
        <TargetPath>%(Filename)%(Extension)</TargetPath>
        <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      </AllPublishItemsFullPathWithTargetPath>
    </ItemGroup>

  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <!-- Target to copy DotNetRuntime to publish directory -->
  <Target Name="CopyDotNetRuntime" 
          AfterTargets="Publish"
          Condition="'$(AppHostRelativeDotNet)' != ''">
    <ItemGroup>
      <_RuntimePackAsset Include="@(RuntimePackAsset)"
                         RuntimePack="$([System.String]::Copy('%(NuGetPackageId)').Replace('.Runtime.win-x64', ''))"
                         RuntimeVersion="%(NuGetPackageVersion)" />
      <_DotNetRuntimeFiles Include="@(_RuntimePackAsset)"
                           TargetPath="shared\%(RuntimePack)\%(RuntimeVersion)\" />
      <_DotNetRuntimeFiles Include="@(_DotNetRuntimeFiles -> '%(RootDir)%(Directory)%(RuntimePack).deps.json');
                              @(_DotNetRuntimeFiles -> '%(RootDir)%(Directory)%(RuntimePack).runtimeconfig.json')"
                           Condition="Exists('%(RootDir)%(Directory)%(RuntimePack).deps.json')" 
                           TargetPath="%(TargetPath)" />
      <_DotNetRuntimeFiles Include="@(RuntimePackAsset)" 
                           Condition="'%(DestinationSubPath)' == 'hostfxr.dll'"
                           TargetPath="" />
      <_DotNetRuntimeFiles Include="@(ResolvedRuntimePack -> '%(PackageDirectory)\LICENSE.TXT');
                              @(ResolvedRuntimePack -> '%(PackageDirectory)\THIRD-PARTY-NOTICES.TXT')"
                           Condition="%(ResolvedRuntimePack.FrameworkName) == 'Microsoft.NETCore.App'" 
                           TargetPath="" />
    </ItemGroup>

    <RemoveDir Directories="$(PublishDir)$(AppHostRelativeDotNet)" />
  
    <Copy SourceFiles="@(_DotNetRuntimeFiles)"
          DestinationFolder="$(PublishDir)$(AppHostRelativeDotNet)\%(TargetPath)" />
  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

</Project>
