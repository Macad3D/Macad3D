<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Icon Conversion from SVG to XAML and Merge into a single Resource Dictionary -->

  <Import Project="Macad.Common.props" Condition="!Exists('$(MMRootDir)')" />
  
<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <PropertyGroup>
      <XamlIconsBaseDirectory>$(BaseIntermediateOutputPath)XamlIcons\</XamlIconsBaseDirectory>
  </PropertyGroup>

  <ItemGroup>
    <!-- Setup some metadata for icon groups dicts -->
    <IconSet Update="@(IconSet)">
      <XamlFile>$(XamlIconsBaseDirectory)%(RelativeDir)%(Filename).xaml</XamlFile>
    </IconSet>
    <IconVariant Update="@(IconVariant)">
      <BasedOnXamlFile>$(XamlIconsBaseDirectory)%(BasedOn).xaml</BasedOnXamlFile>
      <TargetXamlFile>$(XamlIconsBaseDirectory)%(IconVariant.Dictionary).xaml</TargetXamlFile>
    </IconVariant> 

    <!-- Fast up to date check -->
    <UpToDateCheckInput Include="@(IconSet)" />
    <UpToDateCheckInput Include="@(IconSet -> '%(Aliases)')" />
    <UpToDateCheckInput Include="@(IconVariant)" />
    <UpToDateCheckInput Include="@(IconVariant -> '%(BasedOnXamlFile)')" />
  </ItemGroup>

  <!-- Reference the BuildTools project for the icon processing tasks -->
  <ItemGroup Condition="@(IconSet) != '' Or @(IconVariant) != ''">
    <ProjectReference Include="..\..\Tools\BuildTools\BuildTools.csproj"> 
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <SkipGetTargetFrameworkProperties>true</SkipGetTargetFrameworkProperties>
    </ProjectReference>
  </ItemGroup>
  
<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <Target Name="_ConvertSvgFiles"
          Inputs="@(IconSet)"
          Outputs="@(IconSet -> '%(XamlFile)')">

    <PropertyGroup>
      <_IconSvgList>$(XamlIconsBaseDirectory)SvgItemList.txt</_IconSvgList>
      <_IconXamlList>$(XamlIconsBaseDirectory)XamlItemList.txt</_IconXamlList>
    </PropertyGroup>
   
    <ItemGroup>
      <_CurrentIconSet Include="@(IconSet)" />
    </ItemGroup>

    <MakeDir Directories="$(XamlIconsBaseDirectory)" />  
    <WriteLinesToFile File="$(_IconSvgList)" 
                      Lines="@(_CurrentIconSet -> '%(FullPath)')" 
                      Overwrite="true" />
    <WriteLinesToFile File="$(_IconXamlList)" 
                      Lines="@(_CurrentIconSet -> '%(XamlFile)')" 
                      Overwrite="true" />

    <Exec Command="dotnet &quot;$(TargetDir)BuildTools.dll&quot; SvgToXaml In=&quot;$(_IconSvgList)&quot; Out=&quot;$(_IconXamlList)&quot;" />

  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <Target Name="_MergeXamlIcons"
          Inputs="@(IconSet);@(IconSet -> '%(Aliases)')"
          Outputs="$(XamlIconsBaseDirectory)%(Dictionary).xaml">

    <PropertyGroup>
      <_IconList>$(XamlIconsBaseDirectory)IconSet_%(IconSet.Dictionary).txt</_IconList>
    </PropertyGroup>

    <WriteLinesToFile File="$(_IconList)" 
                      Lines="@(IconSet -> '%(XamlFile)')" 
                      Overwrite="true" />
  
    <Exec Command="dotnet &quot;$(TargetDir)BuildTools.dll&quot; MergeIcons In=&quot;$(_IconList)&quot; Out=&quot;$(XamlIconsBaseDirectory)%(IconSet.Dictionary).xaml&quot; Alias=&quot;$(ProjectDir)%(IconSet.Aliases)&quot;" />
  
  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <Target Name="BuildXamlIconSets"
          AfterTargets="ResolveProjectReferences"
          DependsOnTargets="_ConvertSvgFiles;_MergeXamlIcons">
  
    <ItemGroup>
      <Page Include="@(IconSet -> '$(XamlIconsBaseDirectory)%(Dictionary).xaml'->Distinct())" />
    </ItemGroup>
  
  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <Target Name="BuildXamlIconVariants"
          Inputs="@(IconVariant);@(IconVariant -> '%(BasedOnXamlFile)')"
          Outputs="@(IconVariant -> '%(TargetXamlFile)')"
          AfterTargets="ResolveProjectReferences"
          DependsOnTargets="_MergeXamlIcons">

    <Exec Command="dotnet &quot;$(TargetDir)BuildTools.dll&quot; CreateIconsVariant In=&quot;%(IconVariant.BasedOnXamlFile)&quot; Out=&quot;%(IconVariant.TargetXamlFile)&quot; Config=&quot;$(ProjectDir)%(IconVariant.Identity)&quot;" />

    <ItemGroup>
      <Page Include="%(IconVariant.TargetXamlFile)" />
    </ItemGroup>
  
  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

  <Target Name="CleanXamlIconSets"
          AfterTargets="AfterClean">
  
    <RemoveDir Directories="$(XamlIconsBaseDirectory)" />
  
  </Target>

<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
  
</Project>
